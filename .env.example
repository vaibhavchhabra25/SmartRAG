# Default provider is Anthropic (Claude). Set this and the pipeline uses Claude for everything.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Alternative: free-tier provider for local dev without Anthropic credits.
# Leave ANTHROPIC_API_KEY unset, set these two instead, and the pipeline auto-switches to Groq.
# LLM_PROVIDER=groq
# GROQ_API_KEY=gsk_your-key-here

# Optional model overrides (defaults depend on LLM_PROVIDER, see app/config.py)
# GUARDRAIL_MODEL=claude-haiku-4-5-20251001
# JUDGE_MODEL=claude-haiku-4-5-20251001
# ANSWER_MODEL=claude-sonnet-4-6
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
